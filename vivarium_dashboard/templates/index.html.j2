      <summary style="cursor:pointer;font-size:0.88em;color:#555;font-weight:600">Refinements (optional)</summary>
      <div style="padding:12px 0;display:flex;flex-direction:column;gap:8px">
        <label style="font-size:0.88em">bib_key (auto-generated if blank):
          <input type="text" id="ref-bib_key" name="bib_key" placeholder="e.g. Smith2024" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">Title (auto-extracted if blank):
          <input type="text" id="ref-title" name="title" placeholder="Full paper title" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">Authors (semicolon-separated; auto-extracted if blank):
          <input type="text" id="ref-authors" name="authors" placeholder="Smith, J.; Doe, J." style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">Year (auto-extracted if blank):
          <input type="number" id="ref-year" name="year" placeholder="2024" min="1000" max="2100" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">Journal (optional):
          <input type="text" id="ref-journal" name="journal" placeholder="e.g. EcoSal Plus" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">DOI (optional):
          <input type="text" id="ref-doi" name="doi" placeholder="e.g. 10.1145/..." style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
        <label style="font-size:0.88em">Maps to claims (comma-separated, optional):
          <input type="text" id="ref-claim_mappings" name="claim_mappings" placeholder="phase-1.dnaA-accumulation" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
      </div>
    </details>

    <details style="margin-top:8px">
      <summary style="cursor:pointer;font-size:0.88em;color:#555;font-weight:600">Or paste an existing BibTeX entry (no PDF)</summary>
      <div style="padding:12px 0">
        <label style="font-size:0.88em;display:block">BibTeX entry:
          <textarea id="ref-bibtex_text" name="bibtex_text" rows="6" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px;font-family:monospace"
            placeholder="@article{Bremer1996,&#10;  author = {Bremer, H. and Dennis, P.},&#10;  title  = {...},&#10;  ...&#10;}"></textarea>
        </label>
        <label style="font-size:0.88em;display:block">Maps to claims (optional, format: <code>claim-id:bibkey, ...</code>):
          <input type="text" id="ref-bibtex_claim_mappings" name="bibtex_claim_mappings" placeholder="growth-rate-vs-medium:Bremer1996" style="width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:4px;padding:5px 8px">
        </label>
      </div>
    </details>

    <div class="form-error" id="ref-form-error" style="margin-top:8px"></div>
    <div style="margin-top:12px;display:flex;gap:8px">
      <button class="action-btn" style="background:#1976d2;color:#fff;border-color:#1976d2" onclick="submitReferenceForm()">Submit</button>
      <button class="action-btn" onclick="closeModal('modal-reference')">Cancel</button>
    </div>
  </div>
</div>

