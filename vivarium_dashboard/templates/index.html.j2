<!-- DataSource layer (client-fetch seam, sub-project #1).
     __DASH_CONFIG__ sets the data-source mode; data-source.js exposes the
     DataSource global that renderers call to fetch narrative data.
     local-server mode (default) fetches from the same-origin /api/* endpoints.
     Hosted mode (sub-projects #2/#3) will set a different config here. -->
<script>window.__DASH_CONFIG__ = { mode: "local-server" };</script>
<script src="assets/data-source.js"></script>
<script src="assets/render-helpers.js"></script>
<script src="assets/client.js" onerror="/* live mode unavailable */"></script>
<script src="assets/walkthrough.js{% if asset_version %}?v={{ asset_version }}{% endif %}" onerror="/* walkthrough unavailable */"></script>
<script src="assets/github-login.js{% if asset_version %}?v={{ asset_version }}{% endif %}" onerror="/* github-login unavailable */"></script>
<!-- workspace-switcher.js is intentionally not loaded: the left-rail dropdown
     it used to drive has been repurposed into the investigation switcher
     (investigation-switcher.js). The /api/workspaces endpoints remain available
     for CLI tooling. -->
<script src="assets/investigation-switcher.js"></script>
<script>
// Initialize drop zones once walkthrough.js is loaded.
document.addEventListener("DOMContentLoaded", function() {
  if (typeof setupDropZone === "function") {
    setupDropZone("ds-drop-zone", "dataset");
    setupDropZone("ref-pdf-drop-zone", "reference_pdf_primary");
    setupDropZone("expert-drop-zone", "expert_doc");
  }
});

// Dataset form submission.
function _submitDataset(form) {
  submitForm(form, '/api/dataset', function(f) {
    var data = { name: f.name.value.trim(), claims: f.claims.value.trim() };
    var stored = (typeof _dropZoneStore !== "undefined") ? _dropZoneStore["dataset"] : null;
    if (stored && stored.file_b64) {
      data.file_b64 = stored.file_b64;
      data.filename = stored.filename;
    } else {
      var url = f.url.value.trim();
      if (url) {
        data.url = url;
        if (f.sha256.value.trim()) data.sha256 = f.sha256.value.trim();
      } else {
        var errEl = form.querySelector(".form-error");
        if (errEl) errEl.textContent = "Error: drop a file or enter a URL.";
        return null;
      }
    }
    return data;
  });
}

// Reference form submission.
function submitReferenceForm() {
  var errEl = document.getElementById("ref-form-error");
  if (errEl) errEl.textContent = "";

  var pdfStored = (typeof _dropZoneStore !== "undefined") ? _dropZoneStore["reference_pdf_primary"] : null;
  var bibtexText = (document.getElementById("ref-bibtex_text") || {}).value || "";
  bibtexText = bibtexText.trim();

  if (pdfStored && pdfStored.file_b64) {
    var data = { pdf_b64: pdfStored.file_b64, pdf_filename: pdfStored.filename };
    var bibKey    = (document.getElementById("ref-bib_key") || {}).value || "";
    var title     = (document.getElementById("ref-title") || {}).value || "";
    var authors   = (document.getElementById("ref-authors") || {}).value || "";
    var yearStr   = (document.getElementById("ref-year") || {}).value || "";
    var journal   = (document.getElementById("ref-journal") || {}).value || "";
    var doi       = (document.getElementById("ref-doi") || {}).value || "";
    var claims    = (document.getElementById("ref-claim_mappings") || {}).value || "";
    if (bibKey.trim())  data.bib_key  = bibKey.trim();
    if (title.trim())   data.title    = title.trim();
    if (authors.trim()) data.authors  = authors.trim();
    if (yearStr.trim()) data.year     = parseInt(yearStr.trim(), 10);
    if (journal.trim()) data.journal  = journal.trim();
    if (doi.trim())     data.doi      = doi.trim();
    if (claims.trim()) {
      data.claim_mappings = claims.trim().split(",").map(function(s) { return s.trim(); }).filter(Boolean);
    }
    _postReferenceData("/api/reference-pdf", data);

  } else if (bibtexText) {
    var bibClaims = (document.getElementById("ref-bibtex_claim_mappings") || {}).value || "";
    var data = { bibtex_text: bibtexText, claim_mappings: bibClaims.trim() };
    _postReferenceData("/api/reference-bibtex", data);

  } else {
    if (errEl) errEl.textContent = "Error: drop a PDF or paste a BibTeX entry.";
  }
}

function _postReferenceData(endpoint, data) {
  var errEl = document.getElementById("ref-form-error");
  fetch(endpoint, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(data),
  })
    .then(function(res) {
      return res.json().then(function(json) { return { ok: res.ok, status: res.status, json: json }; });
    })
    .then(function(r) {
      if (!r.ok) {
        var msg = (r.json && r.json.error) ? r.json.error : ("HTTP " + r.status);
        if (errEl) errEl.textContent = "Error: " + msg;
        return;
      }
      var branch = r.json.branch || "";
      var commit = r.json.commit || "";
      var bib_key = r.json.bib_key || "";
      var pending = r.json.metadata_pending;
      var msg = "Done!";
      if (bib_key) msg += " bib_key: " + bib_key;
      if (branch)  msg += "\nBranch: " + branch + (commit ? " (" + commit + ")" : "");
      if (pending) msg += "\n\nNote: metadata incomplete — entry marked 'Needs metadata'.";
      fetch("/api/render", { method: "POST" }).finally(function() {
        alert(msg);
        location.reload();
      });
    })
    .catch(function(err) {
      if (errEl) errEl.textContent = "Network error: " + String(err);
    });
}

// Expert doc form submission.
function _submitExpertDoc(form) {
  submitForm(form, '/api/expert-doc', function(f) {
    var stored = (typeof _dropZoneStore !== "undefined") ? _dropZoneStore["expert_doc"] : null;
    if (!stored || !stored.file_b64) {
      var errEl = form.querySelector(".form-error");
      if (errEl) errEl.textContent = "Error: please drop or select a file first.";
      return null;
    }
    var data = {
      name: f.name.value.trim(),
      file_b64: stored.file_b64,
      filename: stored.filename,
    };
    if (f.description && f.description.value.trim()) data.description = f.description.value.trim();
    if (f.contributor && f.contributor.value.trim()) data.contributor = f.contributor.value.trim();
    if (f.claims_supported && f.claims_supported.value.trim()) data.claims_supported = f.claims_supported.value.trim();
    return data;
  });
}

// Visualization form submission — v0.4.2: name + description only.
// (The submitForm call is now inline in the form's onsubmit attribute.)
// Kept as no-op for backward compat with any external callers.
function _submitVisualization(form) {
  submitForm(form, '/api/visualization', function(f) {
    return {
      name: f.viz_name.value.trim(),
      description: f.description ? (f.description.value.trim() || null) : null,
    };
  });
}

// Phase plan submission.
function submitPhasePlan() {
  var errEl = document.getElementById("phase-plan-error");
  if (errEl) errEl.textContent = "";
  var raw = document.getElementById("phase-plan-json").value.trim();
  var phases;
  try {
    phases = JSON.parse(raw);
  } catch (e) {
    if (errEl) errEl.textContent = "Invalid JSON: " + e.message;
    return;
  }
  if (!Array.isArray(phases) || !phases.length) {
    if (errEl) errEl.textContent = "phases must be a non-empty JSON array";
    return;
  }
  fetch("/api/phase-plan", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ phases: phases }),
  })
    .then(function(res) { return res.json().then(function(j) { return { ok: res.ok, json: j }; }); })
    .then(function(r) {
      if (!r.ok) {
        if (errEl) errEl.textContent = "Error: " + (r.json.error || "unknown");
        return;
      }
      fetch("/api/render", { method: "POST" }).finally(function() {
        alert("Phase plan created!\nBranch: " + (r.json.branch || "") + "\nMerge it to make phases appear on main.");
        location.reload();
      });
    })
    .catch(function(err) {
      if (errEl) errEl.textContent = "Network error: " + String(err);
    });
}

// Phase start.
function phaseStart(n) {
  fetch("/api/phase-start", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ n: n }),
  })
    .then(function(res) { return res.json().then(function(j) { return { ok: res.ok, json: j }; }); })
    .then(function(r) {
      if (!r.ok) { alert("Error: " + (r.json.error || "unknown")); return; }
      fetch("/api/render", { method: "POST" }).finally(function() {
        alert("Phase " + n + " started!\nBranch: " + (r.json.branch || ""));
        location.reload();
      });
    })
    .catch(function(err) { alert("Network error: " + err); });
}

// Phase gate.
function phaseGate(n) {
  fetch("/api/phase-gate", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ n: n }),
  })
    .then(function(res) { return res.json().then(function(j) { return { ok: res.ok, json: j }; }); })
    .then(function(r) {
      if (!r.ok) { alert("Error: " + (r.json.error || "unknown")); return; }
      fetch("/api/render", { method: "POST" }).finally(function() {
        alert("Gate evaluated for phase " + n + ": " + (r.json.gate_status || "?") + "\nBranch: " + (r.json.branch || ""));
        location.reload();
      });
    })
    .catch(function(err) { alert("Network error: " + err); });
}

// Run tests.
function runTests() {
  var btn = document.getElementById("run-tests-btn");
  var spinner = document.getElementById("run-tests-spinner");
  var output = document.getElementById("run-tests-output");
  if (btn) btn.disabled = true;
  if (spinner) spinner.style.display = "inline";
  if (output) { output.style.display = "none"; output.textContent = ""; }
  fetch("/api/run-tests", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({}),
  })
    .then(function(res) { return res.json(); })
    .then(function(r) {
      if (btn) btn.disabled = false;
      if (spinner) spinner.style.display = "none";
      if (output) {
        output.style.display = "block";
        var text = "";
        if (r.error) {
          text = "Error: " + r.error;
        } else {
          text = "Exit code: " + r.returncode + "\n\n" + (r.stdout || "") + (r.stderr ? "\nSTDERR:\n" + r.stderr : "");
        }
        output.textContent = text;
      }
    })
    .catch(function(err) {
      if (btn) btn.disabled = false;
      if (spinner) spinner.style.display = "none";
      if (output) { output.style.display = "block"; output.textContent = "Network error: " + err; }
    });
}
</script>
