<!-- Visualization modal -->
<div id="modal-visualization" class="modal-overlay">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('modal-visualization')">&times;</button>
    <h3>Add visualization</h3>
    <p id="viz-already-registered" style="font-size:0.85em;color:#555;margin-bottom:8px"></p>
    <form id="form-visualization" onsubmit="event.preventDefault(); submitForm(this, '/api/visualization', function(f){
      var classVal = (f.viz_class.value || '').trim();
      var cfgRaw = (f.viz_config.value || '').trim();
      var cfg = null;
      if (cfgRaw) {
        try { cfg = JSON.parse(cfgRaw); }
        catch (e) {
          var err = f.querySelector('.form-error');
          if (err) err.textContent = 'Invalid JSON in config: ' + String(e);
          return null;
        }
      }
      return {
        name: f.viz_name.value.trim(),
        description: (f.description.value.trim() || null),
        'class': classVal || null,
        config: cfg,
      };
    })">
      <label>Name <input name="viz_name" pattern="^[a-zA-Z0-9_-]+$" required placeholder="e.g. free_DnaA-trajectory"></label>
      <label>Class (optional &mdash; pick a registered Visualization to make this a configured instance)
        <select name="viz_class" id="viz-class-picker"><option value="">— none (description-only) —</option></select>
      </label>
      <label>Config (JSON; required when a class is picked)
        <textarea name="viz_config" rows="3" placeholder='{"observable": "free_DnaA", "sources": ["baseline"]}'></textarea>
      </label>
      <label>Description (natural language &mdash; required when no class is picked)
