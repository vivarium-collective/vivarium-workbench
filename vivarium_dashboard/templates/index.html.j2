  <div id="investigations-grid">
    <p class="empty-state">Loading studies…</p>
  </div>

  <!-- Detail panel renders inline after a row is clicked -->
  <div id="investigation-detail" style="display:none; margin-top:16px"></div>

  <!--
    Embedded study detail. Replaces the legacy full-window navigation to
    /studies/<name> with an iframe that keeps the dashboard chrome visible.
    The same /studies/<name> route serves both this iframe and the pop-out
    window, so direct links keep working.
  -->
  <div id="study-detail-panel" class="panel" style="display:none; margin-top:16px; padding:0; overflow:hidden">
