<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8"><title>{% if dashboard_name %}{{ dashboard_name }} dashboard{% else %}{{ workspace_name }}{% endif %}{% if active_investigation_name %}:{{ active_investigation_name }}{% endif %}</title>
<link rel="stylesheet" href="assets/style.css{% if asset_version %}?v={{ asset_version }}{% endif %}">
<link rel="stylesheet" href="assets/snapshot-readonly.css">
<script>
// Per-workspace branding (rail logo, title, brand text) is resolved
// server-side at GET / and is NOT re-applied by any client script. The
// cross-workspace switcher navigates between dashboard ports with a full
// location.assign(), so a round-trip switch (workspace A -> B -> A) relies on
// the browser actually re-running GET / for A to restore A's custom branding.
// Modern browsers instead restore A from the back/forward cache (bfcache) — a
// frozen DOM snapshot served WITHOUT a new server render — so A's branding can
// come back stale (the Vivarium default that was showing when A was frozen).
// `Cache-Control: no-store` on sub-resources does not disable page bfcache.
// Force a real reload on bfcache restore so branding is always re-rendered.
window.addEventListener('pageshow', function (e) {
  if (e.persisted) { window.location.reload(); }
});
</script>
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
<style>
/* Modal overlay */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}
.modal-box {
  background: #fff;
  border-radius: 8px;
  padding: 24px 28px;
  min-width: 360px;
  max-width: 560px;
  width: 100%;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  position: relative;
}
.modal-box h3 { margin-top: 0; }
.modal-box label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 0.9em; }
.modal-box input, .modal-box select, .modal-box textarea {
  width: 100%; box-sizing: border-box;
  border: 1px solid #ccc; border-radius: 4px;
  padding: 6px 8px; font-size: 0.92em; margin-bottom: 12px;
}
.modal-box textarea { min-height: 90px; font-family: monospace; }
.modal-box button[type=submit] {
  background: #1976d2; color: #fff; border: none;
  border-radius: 4px; padding: 8px 18px; cursor: pointer; font-size: 0.95em;
}
.modal-box button[type=submit]:disabled { opacity: 0.6; cursor: not-allowed; }
.modal-close {
  position: absolute; top: 10px; right: 14px;
  background: none; border: none; font-size: 1.3em; cursor: pointer; color: #888;
}
.form-error { color: #c00; font-size: 0.9em; margin-top: 4px; min-height: 1.2em; }
.action-btn {
  margin-top: 10px; padding: 5px 12px;
  border: 1px solid #1976d2; background: #e3f2fd;
  border-radius: 4px; cursor: pointer; font-size: 0.88em;
}
.action-btn:hover { background: #bbdefb; }
/* Emitter-type pills for the Simulations DB table */
.emitter-pill {
  display: inline-block; padding: 2px 8px; border-radius: 10px;
  font-size: 12px; font-weight: 500; white-space: nowrap;
}
.emitter-sqlite  { background: #e5e7eb; color: #374151; }   /* gray  */
.emitter-parquet { background: #fef3c7; color: #92400e; }   /* amber */
.emitter-xarray  { background: #ccfbf1; color: #0f766e; }   /* teal  */
.emitter-none    { background: transparent; color: #9ca3af; }   /* no emitter (summary-only) */
.action-btn--secondary {
  margin-top: 10px; padding: 5px 12px;
  border: 1px solid #b91c1c; background: #fef2f2;
  border-radius: 4px; cursor: pointer; font-size: 0.88em; color: #b91c1c;
}
.action-btn--secondary:hover { background: #fee2e2; }
.action-btn-small {
  padding: 2px 8px; border: 1px solid #c62828; background: #ffebee;
  border-radius: 4px; cursor: pointer; font-size: 0.82em; color: #c62828;
}
.action-btn-small:hover { background: #ffcdd2; }
.pill-btn {
  font-size: 0.78em; padding: 2px 8px; border-radius: 3px;
  border: 1px solid #666; background: #fff; cursor: pointer; margin-left: 6px;
  vertical-align: middle;
}
.pill-btn:hover { background: #eee; }
.btn-mini {
  font-size: 0.78em; padding: 2px 8px; border-radius: 3px;
  border: 1px solid #1976d2; background: #e3f2fd; cursor: pointer; margin-left: 8px;
  vertical-align: middle;
}
.btn-mini:hover { background: #bbdefb; }
.section-header {
  margin: 28px 0 6px 0;
  padding-bottom: 6px;
  border-bottom: 2px solid #e0e0e0;
  color: #333;
}
.section-lead {
  color: #666; font-size: 0.92em; margin: 0 0 16px 0; font-style: italic;
}
.source-artifact-tag {
  font-size: 0.78em; color: #555; font-style: italic; margin-left: 8px;
}
#run-tests-output {
  white-space: pre-wrap; font-family: monospace; font-size: 0.82em;
  background: #f8f8f8; border: 1px solid #ccc; border-radius: 4px;
  padding: 10px; margin-top: 10px; max-height: 420px; overflow-y: auto;
  display: none;
}
#run-tests-spinner { display: none; margin-left: 8px; color: #888; }
.panel-lead { color: #6b7280; margin-bottom: 16px; font-size: 0.92em; }
.status-pill.installed{ background:#d1fae5; color:#065f46 }
.status-pill.not_installed{ background:#fef3c7; color:#92400e }
.registry-hint{
  background:#eff6ff; border-left:4px solid #3b82f6; padding:10px 14px;
  border-radius:4px; margin:0 0 16px; font-size:0.92em;
}
/* Composite Explorer editing tab panels (Tasks 4-6 populate these) */
.ce-panel {
  border: 1px solid #eee; border-radius: 4px; padding: 12px; background: #fff;
}

/* Workspace switcher (top of the left rail). */
.viv-workspace-switcher { position: relative; padding: 0; }
/* One dashboard per repo: the workspace name is a built-in FIXTURE — a quiet
   caption sitting directly under the Vivarium brand. NOT a control: no box, no
   background, no border, no hover, default cursor. Just a small status dot + the
   repo name in muted text. */
.viv-workspace-name {
  display: flex; align-items: center; gap: 7px;
  padding: 0 16px 10px;
  margin: 0;
  font-size: 12.5px; font-weight: 600;
  color: #64748b; cursor: default;
  background: none; border: none; border-radius: 0;
}
.viv-workspace-name strong { font-weight: 600; }
.viv-workspace-name .viv-workspace-switcher-glyph { font-size: 8px; }
.viv-workspace-switcher-glyph { color: #2ea043; font-size: 14px; }
.viv-glyph-running { color: #2ea043; }
/* GitHub repo link under the workspace name. */
.viv-rail-repo {
  display: inline-flex; align-items: center; gap: 6px;
  margin: -2px 16px 10px; padding: 3px 8px;
  font-size: 11.5px; font-weight: 500; line-height: 1;
  color: #475569; text-decoration: none;
  border: 1px solid #e2e8f0; border-radius: 6px; background: #f8fafc;
}
.viv-rail-repo:hover { color: #0f172a; border-color: #cbd5e1; background: #f1f5f9; }
.viv-rail-repo svg { flex: none; }
.viv-glyph-stopped { color: #999; }
.viv-glyph-stale   { color: #d29922; }
.viv-glyph-missing { color: #cf222e; }
.viv-ws-error { color: #cf222e; font-size: 11px; padding: 2px 0; }

/* Workspace switcher v2 — centered modal mounted to body. */
.viv-ws-modal {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.32);
  display: none;
  align-items: center; justify-content: center;
  z-index: 2000;
  opacity: 0;
  transition: opacity 0.14s ease-out;
}
.viv-ws-modal.open {
  display: flex;
  opacity: 1;
}
.viv-ws-modal-card {
  width: min(720px, 90vw);
  max-height: 80vh;
  background: #fff;
  border-radius: 8px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.18);
  display: flex; flex-direction: column;
  overflow: hidden;
}
.viv-ws-modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 18px; border-bottom: 1px solid #eee;
}
.viv-ws-modal-header h2 {
  margin: 0; font-size: 15px; font-weight: 600; color: #333;
}
.viv-ws-modal-close {
  background: none; border: none; cursor: pointer;
  font-size: 18px; color: #666; padding: 0 4px;
}
.viv-ws-modal-close:hover { color: #000; }
.viv-ws-modal-list {
  list-style: none; margin: 0; padding: 0;
  overflow-y: auto; flex: 1;
}
.viv-ws-modal-footer {
  padding: 10px 18px; border-top: 1px solid #eee;
}
.viv-ws-modal-add {
  background: none; border: none; color: #0366d6;
  cursor: pointer; font-size: 13px; padding: 0;
}
.viv-ws-modal-add:hover { text-decoration: underline; }

/* Rows */
.viv-ws-row {
  padding: 10px 18px;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
}
.viv-ws-row:last-child { border-bottom: none; }
.viv-ws-row:hover { background: #f6f8fa; }
.viv-ws-row-current { cursor: default; background: #f8f9fb; }
.viv-ws-row-current:hover { background: #f8f9fb; }
.viv-ws-line1 {
  display: flex; align-items: center; gap: 10px;
}
.viv-ws-row .viv-ws-glyph { width: 18px; text-align: center; font-size: 14px; }
.viv-ws-name { flex: 1; font-size: 13px; }
.viv-ws-name small { color: #777; font-weight: normal; }
.viv-ws-path {
  font-size: 11px; color: #888;
  margin-top: 3px; margin-left: 28px;
  word-break: break-all;
}
.viv-ws-action {
  font-size: 11px; padding: 4px 10px; cursor: pointer;
  border: 1px solid #ccc; background: #fff; border-radius: 3px;
}
.viv-ws-action:hover { background: #f0f0f0; }
.viv-ws-action:disabled { opacity: 0.6; cursor: progress; }
.viv-ws-action-danger { color: #cf222e; border-color: #f6c4c9; }
.viv-ws-action-danger:hover { background: #fdecef; }
.viv-ws-action-warn { color: #b3700d; border-color: #f0d8a7; }
.viv-ws-action-warn:hover { background: #fff5e1; }
.viv-ws-action-muted { color: #666; }
.viv-ws-loading {
  padding: 16px 18px; color: #999; font-size: 12px;
}
/* .viv-ws-error reused from v1; no rule change needed. */
.mode-selector { margin: 0.5rem 0; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px; }
.mode-selector legend { font-weight: bold; padding: 0 0.3rem; }
.mode-selector label { display: block; margin: 0.3rem 0; font-weight: normal; }
.viv-workspace-switcher-actions {
  border-top: 1px solid #eee; margin-top: 0.4rem; padding-top: 0.4rem;
}
.viv-workspace-switcher-actions button {
  display: block; width: 100%; text-align: left;
  padding: 0.4rem 0.6rem; background: transparent; border: none; cursor: pointer;
}
.viv-workspace-switcher-actions button:hover { background: #f0f0f0; }

/* Investigation switcher dropdown (anchored under the rail trigger). */
.viv-workspace-switcher { position: relative; }
.viv-iset-menu {
  display: none;
  position: absolute;
  top: calc(100% - 2px);
  left: 12px;
  right: 12px;
  z-index: 1500;
  background: #fff;
  border: 1px solid #d0d7de;
  border-radius: 6px;
  box-shadow: 0 12px 28px rgba(0,0,0,0.14);
  max-height: 60vh;
  overflow-y: auto;
  font-size: 13px;
}
.viv-iset-menu.open { display: block; }
.viv-iset-menu-header {
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em;
  color: #6b7280; padding: 8px 12px 4px;
}
.viv-iset-menu-list { list-style: none; margin: 0; padding: 0; }
.viv-iset-menu-row {
  padding: 8px 12px; cursor: pointer;
  border-top: 1px solid #f3f4f6;
}
.viv-iset-menu-row:first-child { border-top: none; }
.viv-iset-menu-row:hover, .viv-iset-menu-row:focus { background: #f6f8fa; outline: none; }
.viv-iset-menu-row-current { background: #eef4ff; }
.viv-iset-menu-row-current:hover { background: #e3eefe; }
.viv-iset-menu-row-line1 {
  display: flex; align-items: center; gap: 8px;
}
.viv-iset-menu-row-title { flex: 1; font-size: 13px; color: #111827; }
.viv-iset-menu-row-pill {
  font-size: 0.7em !important;
  padding: 1px 7px !important;
  white-space: nowrap;
}
.viv-iset-menu-row-slug {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 11px; color: #6b7280; margin-top: 2px;
}
.viv-iset-menu-row-current-tag { color: #1e40af; font-weight: 600; font-family: inherit; }
.viv-iset-menu-loading, .viv-iset-menu-empty, .viv-iset-menu-error {
  padding: 10px 12px; color: #6b7280; font-size: 12px;
}
.viv-iset-menu-error { color: #b91c1c; }
.viv-iset-menu-divider { border-top: 1px solid #e5e7eb; }
.viv-iset-menu-new {
  display: block; width: 100%; text-align: left;
  background: none; border: none; cursor: pointer;
  padding: 10px 12px; font-size: 13px; color: #0366d6;
}
.viv-iset-menu-new:hover { background: #f6f8fa; }
/* Pass C: cross-worktree section divider + peer-row arrow */
.viv-iset-menu-section {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em;
  color: #6b7280; padding: 10px 12px 4px;
  border-top: 1px solid #e5e7eb;
  background: #fafbfc;
  list-style: none;
}
.viv-iset-menu-row-peer { padding-right: 28px; position: relative; }
.viv-iset-menu-row-arrow {
  color: #6b7280; font-size: 14px; padding-left: 6px;
  flex: 0 0 auto;
}
.viv-iset-menu-row-peer:hover .viv-iset-menu-row-arrow { color: #0366d6; }
</style>
</head><body>

<div class="viv-layout">

  <!-- LEFT RAIL -->
  <aside id="viv-rail" class="viv-rail">

    <!-- Brand: fixed Vivarium logo + name (no per-workspace icon/name override). -->
    <div class="viv-rail-header">
      <img class="viv-rail-logo" src="assets/vivarium-logo.png{% if asset_version %}?v={{ asset_version }}{% endif %}" alt="Vivarium" loading="lazy">
      <div class="viv-rail-brand">
        <strong>Vivarium</strong>
        <small>dashboard</small>
      </div>
    </div>

    <div class="viv-workspace-switcher" id="viv-workspace-switcher">
      <!-- One dashboard per repo: the workspace name is built in here, no switcher. -->
      <div class="viv-workspace-name">
        <span class="viv-workspace-switcher-glyph">●</span>
        <strong>{{ workspace_name }}</strong>
      </div>
    </div>
    <!-- Snapshot mode: static repo label replaces the switcher dropdown. -->
    <div class="viv-repo-label" id="snapshot-repo-label" style="display:none">
      <span class="viv-workspace-switcher-glyph">●</span>
      <strong>{{ workspace_name }}</strong>
    </div>

    {% if repo_url %}
    <!-- Link to the GitHub repository this workspace is associated with
         (derived from `git remote origin`; present in live + published modes). -->
    <a class="viv-rail-repo" href="{{ repo_url }}" target="_blank" rel="noopener"
       title="Open this workspace's GitHub repository">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span>GitHub</span>
    </a>
    {% endif %}

    <!-- Primary nav -->
    <nav class="viv-rail-section" role="tablist">
      <div class="viv-rail-section-label">Workspace</div>
      <!-- Inputs: 3 data streams flowing into a process rectangle (input ports) -->
      <a href="#workspace-inputs"  class="viv-rail-link menu-link" data-page="workspace-inputs">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M2 7h6M2 12h6M2 17h6"/>
            <path d="M7 5l2 2-2 2M7 10l2 2-2 2M7 15l2 2-2 2"/>
            <rect x="12" y="4" width="10" height="16" rx="1"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Sources</span>
      </a>
      <!-- Registry: 3×2 grid of stores — the type catalog. Top row of
           circles (continuous-type stores) over a bottom row of squares
           (discrete/struct-type stores). The mixed-shape pair reads as
           "different KINDS of stores" rather than a uniform grid, which
           better matches the registry's heterogeneous-types semantics. -->
      <a href="#registry"          class="viv-rail-link menu-link" data-page="registry">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <circle cx="6"  cy="7" r="2.2"/>
            <circle cx="12" cy="7" r="2.2"/>
            <circle cx="18" cy="7" r="2.2"/>
            <rect x="3.8"  y="14.8" width="4.4" height="4.4" rx="0.3"/>
            <rect x="9.8"  y="14.8" width="4.4" height="4.4" rx="0.3"/>
            <rect x="15.8" y="14.8" width="4.4" height="4.4" rx="0.3"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Registry</span>
      </a>
      <!-- Composites: composite-as-process — outer boundary containing a process rectangle wired to a store -->
      <a href="#simulation-setup"  class="viv-rail-link menu-link" data-page="simulation-setup">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <rect x="2.5" y="6" width="19" height="12" rx="1.25"/>
            <rect x="5.5" y="9" width="5.5" height="6"/>
            <circle cx="16.5" cy="12" r="2.4"/>
            <path d="M11 12h3.1"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Composites</span>
      </a>
      <!-- Investigations: DAG of related studies. Uses the branching-fan
           icon (previously on the now-removed flat Studies catalog). -->
      <a href="#investigations" class="viv-rail-link menu-link" data-page="investigations">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <rect x="2.5" y="9" width="6" height="6"/>
            <rect x="16" y="3" width="5.5" height="4"/>
            <rect x="16" y="10" width="5.5" height="4"/>
            <rect x="16" y="17" width="5.5" height="4"/>
            <path d="M8.5 12L16 5"/>
            <path d="M8.5 12h7.5"/>
            <path d="M8.5 12L16 19"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Investigations</span>
      </a>
      <a href="#simulations"       class="viv-rail-link menu-link" data-page="simulations">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <ellipse cx="12" cy="6" rx="8" ry="3"/>
            <path d="M4 6v12c0 1.657 3.582 3 8 3s8-1.343 8-3V6"/>
            <path d="M4 12c0 1.657 3.582 3 8 3s8-1.343 8-3"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Simulations DB</span>
      </a>
      <!-- Visualizations: axes + line-chart polyline + data points.
           Polyline style (vs the previous smooth sigmoid) reads more
           clearly as "scientific plot" at rail-icon size — matches the
           chart-icon convention common across viz / analytics UIs and
           the mockup's iconography. -->
      <a href="#visualizations"    class="viv-rail-link menu-link" data-page="visualizations">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <!-- L-shaped axes -->
            <path d="M4 4 V20 H20"/>
            <!-- chart polyline: low-left → peak → dip → higher peak → settle -->
            <path d="M7 16 L 10 11 L 13 14 L 16 8 L 19 10"/>
            <!-- data points at each vertex -->
            <circle cx="7"  cy="16" r="1.05" fill="currentColor" stroke="none"/>
            <circle cx="10" cy="11" r="1.05" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="14" r="1.05" fill="currentColor" stroke="none"/>
            <circle cx="16" cy="8"  r="1.05" fill="currentColor" stroke="none"/>
            <circle cx="19" cy="10" r="1.05" fill="currentColor" stroke="none"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Analyses</span>
      </a>
      <!-- Branch: workspace branch + remote (formerly "GitHub"). The icon
           is a branch-and-node glyph; renaming the label to "Branch"
           better reflects that this tab is about the local branch state,
           the workspace repo's remote, and PR/merge actions — not just
           GitHub-the-product. Hash route #github kept for back-compat
           with bookmarks. -->
      <a href="#github"            class="viv-rail-link menu-link" data-page="github">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <circle cx="6" cy="6" r="2"/>
            <circle cx="6" cy="18" r="2"/>
            <circle cx="18" cy="12" r="2"/>
            <path d="M6 8v8"/>
            <path d="M6 8a6 6 0 0 0 6 6h4"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Branch</span>
      </a>
    </nav>

    <!-- Studies of the active investigation, dependency-ordered. -->
    <div class="viv-rail-section" id="viv-rail-studies-section">
      <div class="viv-rail-section-label">Studies</div>
      <div id="viv-rail-investigations">
        <p class="viv-rail-empty" style="font-size:0.85em;color:#9ca3af;padding:4px 12px">Loading…</p>
      </div>
    </div>

    <!-- Footer: user identity + collapse toggle.
         Workspace owner is resolved from `gh api user` (which requires
         the user to have authenticated `gh auth login`). When that
         succeeds, `owner_login` is the GitHub username and we link to
         their profile. When it doesn't, we fall back to a GENERIC
         "Connect GitHub" prompt — never to git-config name/email —
         so a workspace shown on screen / shared in a screenshot
         doesn't leak the local user's personal git identity. -->
    {% if owner_login %}
    {% set _owner_label = owner_name or owner_login %}
    {% set _owner_sub = '@' + owner_login %}
    {% if owner_html_url %}
    <a class="viv-rail-footer viv-rail-footer-link" href="{{ owner_html_url }}" target="_blank" rel="noopener" title="Open {{ owner_login }} on GitHub ↗">
    {% else %}
    <div class="viv-rail-footer">
    {% endif %}
      {% if owner_avatar_url %}
        <img class="viv-avatar viv-avatar-rail viv-avatar-img" src="{{ owner_avatar_url }}" alt="{{ owner_login }}" loading="lazy" referrerpolicy="no-referrer">
      {% else %}
        <div class="viv-avatar viv-avatar-rail">{{ owner_initials or '—' }}</div>
      {% endif %}
      <div class="viv-rail-footer-text">
        <strong>{{ _owner_label }}</strong>
        <small>{{ _owner_sub }}</small>
      </div>
    {% if owner_html_url %}
    </a>
    {% else %}
    </div>
    {% endif %}
    {% else %}
    {# No GitHub identity → generic prompt linking to gh-cli setup. #}
    <a class="viv-rail-footer viv-rail-footer-link viv-rail-footer-no-github"
       href="https://cli.github.com/manual/gh_auth_login"
       target="_blank" rel="noopener"
       title="Connect this workspace to GitHub — run `gh auth login`">
      <div class="viv-avatar viv-avatar-rail" aria-hidden="true">+</div>
      <div class="viv-rail-footer-text">
        <strong>Connect GitHub</strong>
        <small>run <code>gh auth login</code></small>
      </div>
    </a>
    {% endif %}

    <button class="viv-rail-toggle" id="viv-rail-toggle" type="button" aria-label="Collapse rail" onclick="_vivToggleRail()">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-toggle-svg">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

  </aside>

  <!-- MAIN: topbar + content -->
  <div class="viv-main">

    <!-- Read-only snapshot banner — hidden in local mode; shown when body.snapshot is set.
         The link points at the vivarium-dashboard repo (clone + `vivarium-dashboard
         serve` to run the full interactive dashboard locally); there is no hosted
         interactive version. -->
    <div id="snapshot-banner">
      <span>Read-only snapshot &mdash; run the dashboard locally for the full interactive version.</span>
      <a id="snapshot-interactive-link"
         href="https://github.com/vivarium-collective/vivarium-dashboard#readme"
         target="_blank" rel="noopener">Get vivarium-dashboard on GitHub →</a>
    </div>

    <!-- Top banner removed — was a non-functional breadcrumb + "Coming soon" Share/settings placeholders + a decorative avatar. -->

    <main class="viv-content pages" id="viv-content">

<!-- ===== PAGE: WORKSPACE INPUTS ===== -->
<section id="page-workspace-inputs" class="page" data-page="workspace-inputs">
  <h2 class="page-title">Sources</h2>
  <p class="page-lead">The loaded investigation's sources come first &mdash; the datasets, references, and expert docs it owns. Below them are the repo-wide / shared data sources every investigation can draw on (imported source packages plus shared datasets and references). Simulation modules (the Python packages providing Processes/Steps) live in the <a href="#registry">Registry</a> tab.</p>

  <!-- Investigation-first inputs, rendered client-side from /api/inputs.
       Single source of truth for the datasets/references/expert-docs lists;
       the management panels below provide the add/edit actions + bib explorer. -->
  <div id="inputs-api-render" class="panel">
    <p class="muted" style="font-style:italic">Loading inputs…</p>
  </div>

</section>

<!-- ===== PAGE: SIMULATION SETUP ===== -->
<section id="page-simulation-setup" class="page" data-page="simulation-setup">
  <h2 class="page-title">Composites</h2>
  <p class="page-lead">Browse and explore the composites available in this workspace. Each composite packages a runnable simulation state with parameters you can configure. Click <strong>Explore</strong> to open its wiring diagram and start a Study.</p>

  <!-- Available Composites (workspace-local discovery) -->
  <div class="panel">
    <h3>Available Composites <span id="composite-count" class="count-badge"></span></h3>
    <p class="panel-lead">Discoverable composite documents from <code>pbg_&lt;slug&gt;/composites/*.composite.{yaml,json}</code>. Each one packages a runnable simulation state with parameters you can configure. Click <strong>Explore</strong> to open it in Composite Explorer.</p>
    <div class="card-browse-toolbar" id="composite-toolbar">
      <input type="search" class="card-browse-search" id="composite-search" placeholder="Filter composites…">
      <div class="card-browse-chips" id="composite-tag-chips"></div>
      <span class="card-browse-view-toggle">
        <button class="view-btn active" data-view="grid" onclick="_setCompositeView('grid')" title="Grid view">&#9638;</button>
        <button class="view-btn" data-view="list" onclick="_setCompositeView('list')" title="List view">&#8801;</button>
      </span>
      <select id="composites-sort" class="composites-sort-select" onchange="_setCompositesSort(this.value)" title="Sort composites">
        <option value="workspace-first">Sort: Workspace first</option>
        <option value="name">Sort: Name</option>
        <option value="module">Sort: Module</option>
        <option value="kind">Sort: Kind</option>
      </select>
    </div>
    <div id="composite-cards" class="module-grid">
      <p class="empty-state">Loading composites&hellip;</p>
    </div>
  </div>

</section>

<!-- ===== PAGE: ANALYSES ===== -->
<section id="page-visualizations" class="page" data-page="visualizations">
  <h2 class="page-title">Analyses</h2>
  <p class="page-lead">Analysis scripts and visualization classes available in this workspace. <strong>Analyses</strong> are v2ecoli <code>Analysis</code> steps (registered in <code>ANALYSIS_REGISTRY</code>) that post-process simulation output. <strong>Visualizations</strong> are chart classes (subclasses of <code>pbg_superpowers.visualization.Visualization</code>) that render observable trajectories — configure one with specific settings or generate a new one with <code>/pbg-viz</code>.</p>


  <!-- Available Analysis + Visualization classes (catalog) -->
  <div class="panel">
    <h3>Available classes <span id="viz-count" class="count-badge"></span></h3>
    <p class="panel-lead">Classes discovered from the installed environment. Analyses are <code>v2ecoli</code> <code>ANALYSIS_REGISTRY</code> entries; Visualizations are <code>pbg_superpowers.visualization.Visualization</code> subclasses. Click <strong>Preview</strong> (Visualizations only) to see a demo render; <strong>Use</strong> to register a Visualization in this workspace. Need a new visualization? Run <code>/pbg-viz &lt;name&gt; &lt;description&gt;</code> in Claude Code.</p>
    <input type="search" id="viz-catalog-search" placeholder="Search classes by name or doc…"
           style="width:100%;padding:6px;margin-bottom:8px;font-size:0.9em"
           oninput="_filterVizCatalog(this.value)">
    <div id="viz-picker-container">
      <p class="empty-state">Discovering classes&hellip; <span class="muted">First load walks the installed environment and can take a few seconds; subsequent loads are cached for 30 s.</span></p>
    </div>
  </div>

</section>

<!-- Preview modal (iframe-based) -->
<div id="modal-viz-preview" class="modal-overlay">
  <div class="modal-box" style="max-width:900px">
    <button class="modal-close" onclick="closeModal('modal-viz-preview')">&times;</button>
    <h3 id="viz-preview-title">Preview</h3>
    <div id="viz-preview-source-row" style="margin-bottom:8px;font-size:0.9em;color:#555"></div>
    <iframe id="viz-preview-iframe" style="width:100%;height:480px;border:1px solid #ddd;background:#fff"></iframe>
    <div id="viz-preview-notes" style="margin-top:8px;font-size:0.85em;color:#666"></div>
  </div>
</div>

<!-- Data-source file preview modal (repo-wide data sources, Inputs tab) -->
<div id="modal-ds-preview" class="modal-overlay">
  <div class="modal-box" style="max-width:900px">
    <button class="modal-close" onclick="closeModal('modal-ds-preview')">&times;</button>
    <h3 style="margin-bottom:8px">Data source: <code id="ds-preview-title" style="font-size:0.85em"></code></h3>
    <div style="margin-bottom:8px">
      <a id="ds-preview-download" class="action-btn" download>Download</a>
    </div>
    <pre id="ds-preview-body" style="max-height:560px;overflow:auto;background:#0f172a;color:#e2e8f0;padding:12px;border-radius:6px;font-size:0.8em;line-height:1.4;white-space:pre;margin:0"></pre>
  </div>
</div>

<!-- ===== PAGE: REGISTRY ===== -->
<section id="page-registry" class="page" data-page="registry">
  <h2 class="page-title">Registry</h2>
  <p class="page-lead">Simulation modules: browse the catalog, install pbg-* packages, see what processes and types they contribute. Installing a module adds it as a submodule under <code>external/</code>, pip-installs it into the workspace venv, and appends it to <code>pyproject.toml</code> dependencies.</p>

  {# Page-level sub-tabs.
     The Registry page used to render three stacked panels (Available
     modules → Installed modules → Discovered registry), which forced
     users to scroll through a long catalog grid every time they wanted
     to consult the build_core() introspection. Split into two sub-tabs:
       Modules    — catalog grid (workspace package + installed entries
                    pinned at top, then everything else).
       Discovered — live build_core() introspection.
     The separate "Installed modules" table was folded into the catalog
     grid itself; each card carries its own uninstall affordance + path
     /source info, so the table was redundant. #}
  <div class="registry-subtabs" role="tablist">
    <button class="registry-subtab active" data-subtab="modules"
            onclick="_setRegistrySubtab('modules')" role="tab">Modules</button>
    <button class="registry-subtab" data-subtab="discovered"
            onclick="_setRegistrySubtab('discovered')" role="tab">Discovered registry
      <span class="count-badge muted" id="registry-total-count"></span></button>
  </div>

  <!-- Subtab: Modules (catalog grid; workspace + installed entries pinned at top) -->
  <section class="panel registry-subtab-panel active" data-subtab="modules">
    <p class="panel-lead">Modules active in this workspace appear at the top (the workspace's own first-party package is pinned first, then installed catalog modules). Click Install on any card below to add it. Each installed card carries an Uninstall affordance + its source / path.</p>
    <div class="card-browse-toolbar" id="catalog-toolbar">
      <input type="search" class="card-browse-search" id="catalog-search" placeholder="Filter modules…">
      <div class="card-browse-chips" id="catalog-tag-chips"></div>
      <div class="card-browse-options">
        <label><input type="radio" name="catalog-installed-filter" value="all" checked> All</label>
        <label><input type="radio" name="catalog-installed-filter" value="installed"> Installed</label>
        <label><input type="radio" name="catalog-installed-filter" value="uninstalled"> Available</label>
        <span class="card-browse-view-toggle">
          <button class="view-btn active" data-view="grid" onclick="_setCatalogView('grid')" title="Grid view">&#9638;</button>
          <button class="view-btn" data-view="list" onclick="_setCatalogView('list')" title="List view">&#8801;</button>
        </span>
      </div>
    </div>
    <div id="catalog-modules-grid" class="module-grid">
      <p class="empty-state">Loading catalog&hellip;</p>
    </div>
    {# Sync-warning element preserved (some installed entries can fall
       out of sync with pyproject.toml; the warning banner pops up here). #}
    <div id="installed-modules-sync-warning" style="display:none"></div>
    {# Legacy `installed-modules-list` div kept (empty, hidden) so any JS
       paths that target it (e.g. _renderInstalledModules) no-op cleanly
       instead of throwing. Removable once those callsites are pruned. #}
    <div id="installed-modules-list" hidden></div>
    <span id="installed-modules-count" hidden></span>
  </section>

  <!-- Subtab: Discovered registry (live build_core() introspection) -->
  <section class="panel registry-subtab-panel" data-subtab="discovered">
    <p class="panel-lead">Live snapshot of <code>build_core()</code> — every Process, Step, Emitter, Visualization, and Type registered via auto-discovery. Classes from this workspace's own package and declared <code>imports</code> are shown first. Classes discovered from the Python environment but <em>not</em> declared in <code>workspace.yaml</code> appear collapsed under <em>Also available in environment</em>.</p>

    <button class="action-btn" onclick="_loadRegistry(true)">Refresh registry</button>
    <div id="registry-status" class="muted" style="margin:8px 0"></div>

    <div class="registry-tabs">
      <button class="registry-tab active" data-kind="process"       onclick="_setRegistryTab('process')">Processes <span class="count-badge" id="registry-process-count"></span></button>
      <button class="registry-tab"        data-kind="step"          onclick="_setRegistryTab('step')">Steps <span class="count-badge" id="registry-step-count"></span></button>
      <button class="registry-tab"        data-kind="emitter"       onclick="_setRegistryTab('emitter')">Emitters <span class="count-badge" id="registry-emitter-count"></span></button>
      <button class="registry-tab"        data-kind="visualization" onclick="_setRegistryTab('visualization')">Visualizations <span class="count-badge" id="registry-visualization-count"></span></button>
      <button class="registry-tab"        data-kind="type"          onclick="_setRegistryTab('type')">Types <span class="count-badge" id="registry-type-count"></span></button>
    </div>

    <input type="search" class="registry-search" id="registry-search" placeholder="Filter&hellip;" oninput="_filterRegistry(this.value)">

    <div class="registry-tab-panel active" data-kind="process"       id="registry-processes-container"><p class="empty-state">Loading&hellip;</p></div>
    <div class="registry-tab-panel"        data-kind="step"          id="registry-steps-container"></div>
    <div class="registry-tab-panel"        data-kind="emitter"       id="registry-emitters-container"></div>
    <div class="registry-tab-panel"        data-kind="visualization" id="registry-visualizations-container"></div>
    <div class="registry-tab-panel"        data-kind="type"          id="registry-types-container"></div>
  </section>
</section>

<!-- ===== PAGE: STUDIES ===== -->
<section id="page-investigations" class="page" data-page="investigations">
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
    <h2 class="page-title" style="margin:0">Investigations</h2>
    <div style="display:flex;gap:8px;align-items:center">
      <!-- "Switch investigation" + "+ New Investigation" actions now live in
           the left-rail investigation switcher dropdown (top of the rail). -->
    </div>
  </div>
  <p class="page-lead" id="investigation-page-lead">All investigations in this repo. Select one to open it — its studies appear in the left rail. Merged investigations are preserved as artifacts; in-progress ones live on their branch/PR.</p>

  <!-- List view: investigation cards. -->
  <div id="investigations-list" class="investigations-list-grid" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap:12px;">
    <p class="empty-state">Loading…</p>
  </div>

  <!-- "+ New Investigation" modal. Hidden by default. -->
  <div id="new-iset-modal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.4); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:8px; padding:20px 22px; width:min(540px, 92vw); max-height:90vh; overflow:auto; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <h3 style="margin:0">New Investigation</h3>
        <button class="btn-mini" onclick="_closeNewIsetModal()">×</button>
      </div>
      <div id="new-iset-error" style="display:none; background:#fee2e2; color:#991b1b; padding:8px 12px; border-radius:6px; margin-bottom:10px; font-size:0.9em;"></div>
      <label style="display:block; margin-bottom:10px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Name <span style="color:#dc2626">*</span></div>
        <input type="text" id="new-iset-name" oninput="_updateNewIsetSlugPreview()" placeholder="My new investigation"
               style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em;">
        <div class="muted" style="font-size:0.8em; margin-top:4px;">
          Slug: <code id="new-iset-slug-preview" style="background:#f3f4f6; padding:1px 4px; border-radius:3px;">—</code>
        </div>
      </label>
      <label style="display:block; margin-bottom:10px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Overview <span class="muted" style="font-weight:normal;">(optional)</span></div>
        <textarea id="new-iset-overview" rows="3"
                  style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em; font-family:inherit; resize:vertical;"
                  placeholder="One- or two-line description of the research arc."></textarea>
      </label>
      <label style="display:block; margin-bottom:14px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Parent studies <span class="muted" style="font-weight:normal;">(optional, hold ⌘/Ctrl to multi-select)</span></div>
        <select id="new-iset-parent-studies" multiple size="5"
                style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em;"></select>
      </label>
      <div style="display:flex; justify-content:flex-end; gap:8px;">
        <button class="btn-mini" onclick="_closeNewIsetModal()">Cancel</button>
        <button class="action-btn" id="new-iset-submit-btn" onclick="_submitNewIset()">Create</button>
      </div>
    </div>
  </div>

  <!-- "Clone investigation" modal. Hidden by default. -->
  <div id="clone-iset-modal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.4); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:8px; padding:20px 22px; width:min(540px, 92vw); max-height:90vh; overflow:auto; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <h3 style="margin:0">Clone investigation</h3>
        <button class="btn-mini" onclick="_closeCloneIsetModal()">×</button>
      </div>
      <div id="clone-iset-error" style="display:none; background:#fee2e2; color:#991b1b; padding:8px 12px; border-radius:6px; margin-bottom:10px; font-size:0.9em;"></div>
      <p class="muted" style="font-size:0.85em; margin:0 0 12px 0;">
        Copies the investigation + its studies, strips simulation results, resets statuses to <code>planning</code>.
        Useful for a fresh attempt at the same plan or a demo fixture.
      </p>
      <label style="display:block; margin-bottom:10px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Source <span class="muted" style="font-weight:normal;">(this investigation)</span></div>
        <input type="text" id="clone-iset-source" readonly
               style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em; background:#f9fafb; color:#475569;">
      </label>
      <label style="display:block; margin-bottom:10px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Target name <span style="color:#dc2626">*</span></div>
        <input type="text" id="clone-iset-target" oninput="_updateCloneIsetSlugPreview()" placeholder="e.g. dnaa-replication-fresh"
               style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em;">
        <div class="muted" style="font-size:0.8em; margin-top:4px;">
          Slug: <code id="clone-iset-slug-preview" style="background:#f3f4f6; padding:1px 4px; border-radius:3px;">—</code>
        </div>
      </label>
      <label style="display:block; margin-bottom:14px;">
        <div style="font-weight:600; font-size:0.9em; margin-bottom:4px;">Target study prefix <span class="muted" style="font-weight:normal;">(optional)</span></div>
        <input type="text" id="clone-iset-target-prefix" placeholder="defaults to first dash-segment of target name"
               style="width:100%; padding:6px 8px; border:1px solid #d1d5db; border-radius:4px; font-size:0.95em;">
        <div class="muted" style="font-size:0.8em; margin-top:4px;">
          Studies like <code>dnaa-02-atp-hydrolysis</code> become <code>&lt;prefix&gt;-02-atp-hydrolysis</code>.
        </div>
      </label>
      <div style="display:flex; justify-content:flex-end; gap:8px;">
        <button class="btn-mini" onclick="_closeCloneIsetModal()">Cancel</button>
        <button class="action-btn" id="clone-iset-submit-btn" onclick="_submitCloneIset()">Clone</button>
      </div>
    </div>
  </div>

  <!-- Detail view: one investigation's DAG. Toggled on click. -->
  <div id="investigation-detail-view" style="display:none; margin-top:8px">
    <button class="iset-back-link" onclick="_showInvestigationList()" title="Back to all investigations"
            style="background:none; border:none; padding:0; margin:0 0 4px; color:#64748b; font-size:0.82em; cursor:pointer; display:inline-flex; align-items:center; gap:4px">&larr; All investigations</button>
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
      <h3 id="investigation-detail-title" style="margin:0; flex:1"></h3>
      <span id="investigation-detail-status" class="status-pill planned" style="font-size:0.85em"></span>
      <span class="viv-info-chip" data-tooltip="Run unblocked &mdash; queue every variant whose model_settings don&#39;t have any unset &#39;required-before-run&#39; gates. Sequential, one variant at a time on a background thread.&#10;&#10;Refresh &mdash; re-fetch the investigation from disk. Use after editing YAML files directly.&#10;&#10;Generate report &mdash; self-contained HTML report you can email.&#10;&#10;Clone &mdash; copy this investigation into a fresh planning state with no run results.">?</span>
      <button class="btn-mini" id="investigation-detail-refresh" onclick="_refreshInvestigationDetail()" title="Re-fetch the investigation + its studies from disk. Use after editing YAML files directly (which the dashboard can't see otherwise).">↻ Refresh</button>
      <button class="btn-mini" id="investigation-run-unblocked" onclick="_runUnblockedSimulations()" title="Run every variant whose model_settings don't have any unset 'required-before-run' gates. Sequential — one variant at a time on a background thread. Progress shown in the panel below.">▶ Run unblocked</button>
      <button class="btn-mini" onclick="_generateInvestigationReport()" title="Generate a shareable HTML report (self-contained, attach to email)">Generate report 📄</button>
      <button class="btn-mini" onclick="_openCloneIsetModal()" title="Clone this investigation into a fresh planning state (no run results). Useful for a parallel attempt or a demo fixture.">Clone ⎘</button>
    </div>
    <!-- Run-progress panel: rendered while a run-unblocked job is active. -->
    <div id="investigation-run-progress" class="inv-run-progress" style="display:none"></div>

    <div id="investigation-intro" class="inv-intro" style="margin: 0 0 16px 0;">
      <!-- Lead paragraph (the abstract). Auto-styled as serif body type for readability. -->
      <div id="investigation-detail-description" class="inv-lead"></div>
      <!-- At-a-glance grid: one tile per study with a one-line role. Populated by JS. -->
      <div id="investigation-at-a-glance" class="inv-at-a-glance" style="display:none"></div>
      <!-- How to read this: ordered list of usage tips for the evaluator. -->
      <details id="investigation-how-to-read" class="inv-how-to-read" style="display:none">
        <summary>How to read this</summary>
        <ol></ol>
      </details>
      <!-- Glossary: collapsible. -->
      <details id="investigation-glossary" class="inv-glossary" style="display:none">
        <summary>Glossary</summary>
        <dl></dl>
      </details>
      <!-- Biology story (free-form prose). Hidden if the yaml omits it. -->
      <details id="investigation-biology-story" class="inv-bio-story" style="display:none">
        <summary class="inv-bio-story-label">Biology — the mechanism this investigation models</summary>
        <div id="investigation-biology-story-text" class="inv-bio-story-text"></div>
      </details>
      <!-- SP5: Needs-attention panel. Populated by JS from /api/needs-attention. -->
      <div id="investigation-needs-attention"></div>
    </div>
    <!-- Discourse-graph framing: studies as knowledge-producing operations. -->
    <div id="investigation-dag-lead" style="margin: 4px 0 8px; font-size: 0.88em; color: #475569; line-height: 1.4;">
      <strong>Investigation graph</strong> — each study is a knowledge-producing operation that
      builds understanding of the mechanism. Each node shows the <em>question</em> it asks and
      the <em>evidence</em> it produced; edges show what a result leads to.
    </div>
    <div id="investigation-dag-shell"
         style="position: relative; border: 1px solid #e2e8f0; border-radius: 6px; background: #fafafa;
                overflow-x: auto; overflow-y: hidden;">
      <!-- overflow-y must be hidden (not visible): per CSS spec, when one axis
           is `visible` and the other isn't, `visible` gets promoted to `auto`,
           which gives this shell its own vertical scrollbar in addition to
           .viv-content's. JS sets shell.style.height = canvasH so the full
           DAG fits and the parent .viv-content handles vertical scroll. -->
      <svg id="investigation-dag-edges" style="position:absolute; top:0; left:0; pointer-events:none;"></svg>
      <div id="investigation-dag-nodes" style="position:relative; top:0; left:0;"></div>
    </div>

    <!-- In-place study embed: when a DAG node is clicked, the full study
         loads below in an iframe (same /studies/<name> route the Studies
         page uses). Pop-out button breaks it into a separate window. -->
    <div id="investigation-study-embed-panel" class="panel"
         style="display:none; margin-top:16px; padding:0; overflow:hidden">
      <div style="display:flex; align-items:center; justify-content:space-between; padding:8px 12px; border-bottom:1px solid #e5e7eb; background:#f9fafb">
        <strong id="investigation-study-embed-name" style="font-size:1.05em"></strong>
        <div style="display:flex; gap:6px">
          <button class="btn-mini" onclick="_popoutInvestigationStudy()" title="Open in a separate window. If it opens as a tab, your browser's 'open new pages as tabs' preference is overriding the popup hint (Safari → Tabs → 'Open pages in tabs instead of windows' → set to 'Manually').">Pop out ↗</button>
          <button class="btn-mini" onclick="_closeInvestigationStudyEmbed()" title="Close">×</button>
        </div>
      </div>
      <!-- Explicit height = its own scroll context, so `position:sticky` on
           .study-tabs (inside the iframe) actually sticks to the iframe top
           as the user scrolls through Overview → Build → … → Decide. -->
      <iframe id="investigation-study-embed-frame" src="" title="Study detail"
              style="width:100%; height:calc(100vh - 220px); min-height:600px;
                     border:0; display:block"></iframe>
    </div>
  </div>
</section>

