<!-- Reference modal -->
<div id="modal-reference" class="modal-overlay">
  <div class="modal-box" style="max-width:600px">
    <button class="modal-close" onclick="closeModal('modal-reference')">&times;</button>
    <h3>Add reference</h3>
    <p class="subtitle" style="font-size:0.85em;color:#555;margin-bottom:12px">
      Drop a PDF &mdash; metadata is auto-extracted from the PDF&rsquo;s embedded fields.
    </p>

    <label style="margin-bottom:4px;font-weight:600">Drop a PDF here *</label>
    <div id="ref-pdf-drop-zone" class="drop-zone">
