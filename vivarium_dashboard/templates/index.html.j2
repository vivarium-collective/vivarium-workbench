    <select id="investigations-sort" onchange="_setInvestigationsSort(this.value)" style="margin-left:12px">
      <option value="dependencies" selected>Sort: Dependencies (topological)</option>
      <option value="name">Sort: Name</option>
      <option value="last_run">Sort: Last run</option>
      <option value="status">Sort: Status</option>
      <option value="phase">Sort: Phase (Design → Decide)</option>
      <option value="topic">Sort: Topic</option>
