<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8"><title>{{ workspace_name }}</title>
<link rel="stylesheet" href="assets/style.css">
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
<style>
/* Modal overlay */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}
.modal-box {
  background: #fff;
  border-radius: 8px;
  padding: 24px 28px;
  min-width: 360px;
  max-width: 560px;
  width: 100%;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  position: relative;
}
.modal-box h3 { margin-top: 0; }
.modal-box label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 0.9em; }
.modal-box input, .modal-box select, .modal-box textarea {
  width: 100%; box-sizing: border-box;
  border: 1px solid #ccc; border-radius: 4px;
  padding: 6px 8px; font-size: 0.92em; margin-bottom: 12px;
}
.modal-box textarea { min-height: 90px; font-family: monospace; }
.modal-box button[type=submit] {
  background: #1976d2; color: #fff; border: none;
  border-radius: 4px; padding: 8px 18px; cursor: pointer; font-size: 0.95em;
}
.modal-box button[type=submit]:disabled { opacity: 0.6; cursor: not-allowed; }
.modal-close {
  position: absolute; top: 10px; right: 14px;
  background: none; border: none; font-size: 1.3em; cursor: pointer; color: #888;
}
.form-error { color: #c00; font-size: 0.9em; margin-top: 4px; min-height: 1.2em; }
.action-btn {
  margin-top: 10px; padding: 5px 12px;
  border: 1px solid #1976d2; background: #e3f2fd;
  border-radius: 4px; cursor: pointer; font-size: 0.88em;
}
.action-btn:hover { background: #bbdefb; }
.action-btn--secondary {
  margin-top: 10px; padding: 5px 12px;
  border: 1px solid #b91c1c; background: #fef2f2;
  border-radius: 4px; cursor: pointer; font-size: 0.88em; color: #b91c1c;
}
.action-btn--secondary:hover { background: #fee2e2; }
.action-btn-small {
  padding: 2px 8px; border: 1px solid #c62828; background: #ffebee;
  border-radius: 4px; cursor: pointer; font-size: 0.82em; color: #c62828;
}
.action-btn-small:hover { background: #ffcdd2; }
.pill-btn {
  font-size: 0.78em; padding: 2px 8px; border-radius: 3px;
  border: 1px solid #666; background: #fff; cursor: pointer; margin-left: 6px;
  vertical-align: middle;
}
.pill-btn:hover { background: #eee; }
.btn-mini {
  font-size: 0.78em; padding: 2px 8px; border-radius: 3px;
  border: 1px solid #1976d2; background: #e3f2fd; cursor: pointer; margin-left: 8px;
  vertical-align: middle;
}
.btn-mini:hover { background: #bbdefb; }
.section-header {
  margin: 28px 0 6px 0;
  padding-bottom: 6px;
  border-bottom: 2px solid #e0e0e0;
  color: #333;
}
.section-lead {
  color: #666; font-size: 0.92em; margin: 0 0 16px 0; font-style: italic;
}
.source-artifact-tag {
  font-size: 0.78em; color: #555; font-style: italic; margin-left: 8px;
}
#run-tests-output {
  white-space: pre-wrap; font-family: monospace; font-size: 0.82em;
  background: #f8f8f8; border: 1px solid #ccc; border-radius: 4px;
  padding: 10px; margin-top: 10px; max-height: 420px; overflow-y: auto;
  display: none;
}
#run-tests-spinner { display: none; margin-left: 8px; color: #888; }
.panel-lead { color: #6b7280; margin-bottom: 16px; font-size: 0.92em; }
.status-pill.installed{ background:#d1fae5; color:#065f46 }
.status-pill.not_installed{ background:#fef3c7; color:#92400e }
.registry-hint{
  background:#eff6ff; border-left:4px solid #3b82f6; padding:10px 14px;
  border-radius:4px; margin:0 0 16px; font-size:0.92em;
}
/* Composite Explorer editing tab panels (Tasks 4-6 populate these) */
.ce-panel {
  border: 1px solid #eee; border-radius: 4px; padding: 12px; background: #fff;
}
</style>
</head><body>

<div class="viv-layout">

  <!-- LEFT RAIL -->
  <aside id="viv-rail" class="viv-rail">

    <!-- Brand + workspace switcher -->
    <div class="viv-rail-header">
      <img class="viv-rail-logo" src="assets/vivarium-logo.png" alt="Vivarium" loading="lazy">
      <div class="viv-rail-brand">
        <strong>Vivarium</strong>
        <small>dashboard</small>
      </div>
    </div>

    <div class="viv-workspace-switcher viv-tooltip" data-tooltip="Other workspaces coming soon">
      <strong>{{ workspace_name }}</strong> <span class="viv-arrow">▾</span>
    </div>

    <!-- Primary nav -->
    <nav class="viv-rail-section" role="tablist">
      <div class="viv-rail-section-label">Workspace</div>
      <a href="#workspace-inputs"  class="viv-rail-link menu-link" data-page="workspace-inputs">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z"/>
            <path d="M13 3v6h6"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Workspace inputs</span>
      </a>
      <a href="#registry"          class="viv-rail-link menu-link" data-page="registry">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Registry</span>
      </a>
      <a href="#simulation-setup"  class="viv-rail-link menu-link" data-page="simulation-setup">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Composites</span>
      </a>
      <a href="#investigations"    class="viv-rail-link menu-link" data-page="investigations">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Investigations</span>
      </a>
      <a href="#visualizations"    class="viv-rail-link menu-link" data-page="visualizations">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">Visualizations</span>
      </a>
      <a href="#branches"          class="viv-rail-link menu-link" data-page="branches">
        <span class="viv-rail-link-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-link-svg">
            <circle cx="6" cy="5" r="2"/>
            <circle cx="6" cy="19" r="2"/>
            <circle cx="18" cy="12" r="2"/>
            <path d="M6 7v10"/>
            <path d="M6 12h6a4 4 0 0 0 4-4V7"/>
          </svg>
        </span>
        <span class="viv-rail-link-label">GitHub Branches</span>
      </a>
    </nav>

    <!-- Investigations grouped list -->
    <div class="viv-rail-section">
      <div class="viv-rail-section-label">Studies</div>
      <div id="viv-rail-investigations">
        <p class="viv-rail-empty" style="font-size:0.85em;color:#9ca3af;padding:4px 12px">Loading…</p>
      </div>
    </div>

    <!-- Footer: user identity + collapse toggle -->
    <div class="viv-rail-footer">
      <div class="viv-avatar viv-avatar-rail">{{ owner_initials or '—' }}</div>
      <div class="viv-rail-footer-text">
        <strong>{{ owner_name or 'Workspace owner' }}</strong>
        <small>{{ owner_email or '' }}</small>
      </div>
    </div>

    <button class="viv-rail-toggle" id="viv-rail-toggle" type="button" aria-label="Collapse rail" onclick="_vivToggleRail()">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="viv-rail-toggle-svg">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

  </aside>

  <!-- MAIN: topbar + content -->
  <div class="viv-main">

    <header class="viv-topbar">
      <nav class="viv-topbar-breadcrumbs" id="viv-breadcrumbs">
        <span>{{ workspace_name }} dashboard</span>
      </nav>
      <div class="viv-topbar-actions" id="viv-topbar-actions">
        <!-- Branch chip + dirty pill + work-status buttons populated by JS (V4) -->
        <span class="viv-branch-chip" id="viv-branch-chip">…</span>
        {% if github_url %}<a class="viv-icon-btn" href="{{ github_url }}" target="_blank" rel="noopener" title="Open on GitHub">↗</a>{% endif %}
        <span class="viv-btn viv-tooltip" data-tooltip="Coming soon — share workspace link">Share</span>
        <span class="viv-kebab viv-tooltip" data-tooltip="Workspace settings — coming soon">⋯</span>
        <span class="viv-avatar viv-avatar-topbar" title="{{ owner_email or '' }}">{{ owner_initials or '—' }}</span>
      </div>
    </header>

    <!-- Workstream strip is now driven by viv-topbar-actions; this hidden node
         preserves the existing _renderWorkStrip JS contract until V4 lifts it. -->
    <div id="workstream-strip" class="workstream-strip" style="display:none"></div>

    <main class="viv-content pages" id="viv-content">

<!-- ===== PAGE: WORKSPACE INPUTS ===== -->
<section id="page-workspace-inputs" class="page" data-page="workspace-inputs">
  <h2 class="page-title">Workspace inputs</h2>
  <p class="page-lead">External resources you bring into the workspace. Datasets feed validation, references and expert docs anchor the science. Simulation modules (the Python packages providing Processes/Steps) live in the <a href="#registry">Registry</a> tab.</p>

  <!-- Datasets panel -->
  <div class="panel">
    <h3>Datasets</h3>
    <p class="panel-lead">Register datasets your model will compare against. Each entry maps to specific model claims it supports.</p>
    {% if datasets %}
    <table><thead><tr><th>Name</th><th>Source</th><th>Claims</th></tr></thead><tbody>
    {% for ds in datasets %}
    <tr>
      <td><code>{{ ds.name }}</code></td>
      <td>
        {% if ds.file_exists %}
          {% if ds.sha256_valid == False %}<span class="file-status status-mismatch">⚠ sha mismatch</span>{% else %}<span class="file-status status-ok">✓ {{ ds.size_human }}</span>{% endif %}
          <a href="/{{ ds.path }}" target="_blank" class="file-link">Open ↗</a><br>
          <small class="muted">{{ ds.path }}</small>
        {% elif ds.file_exists == False %}
          <span class="file-status status-missing">⚠ missing</span><br>
          <small class="muted">{{ ds.path }}</small>
        {% elif ds.url %}
          <a href="{{ ds.url }}" target="_blank" class="file-link">{{ ds.url }} ↗</a>
        {% else %}
          <small class="muted">{{ ds.path or '(no source)' }}</small>
        {% endif %}
      </td>
      <td>{{ (ds.claims or [])|join(', ') }}</td>
    </tr>
    {% endfor %}
    </tbody></table>
    {% else %}
    <p style="color:#888;font-style:italic">No datasets registered yet.</p>
    {% endif %}
    <button class="action-btn" onclick="openModal('modal-dataset')">+ Add dataset</button>
  </div>

  <!-- References panel -->
  <div class="panel">
    <h3>References</h3>
    <p class="panel-lead">BibTeX bibliography + claim &rarr; paper mapping. Adds entries to <code>references/papers.bib</code> and <code>references/claims.yaml</code>.</p>
    <p>Entries in <code>references/papers.bib</code>: <strong>{{ references_count }}</strong> &nbsp;&middot;&nbsp; PDFs committed: <strong>{{ (references_pdfs or [])|length }}</strong></p>
    {% if references_pdfs %}
    <table style="font-size:0.86em;margin-bottom:10px"><thead><tr><th>Bib key</th><th>File</th></tr></thead><tbody>
    {% for pdf in references_pdfs %}
    <tr>
      <td><code>{{ pdf.bib_key }}</code>{% if pdf._metadata_pending %} <span class="stage-label optional">Needs metadata</span>{% endif %}</td>
      <td>
        {% if pdf.file_exists %}
          {% if pdf.sha256_valid == False %}<span class="file-status status-mismatch">⚠ sha mismatch</span>{% else %}<span class="file-status status-ok">✓ {{ pdf.size_human }}</span>{% endif %}
          <a href="/{{ pdf.path }}" target="_blank" class="file-link">Open ↗</a><br>
          <small class="muted">{{ pdf.path }}</small>
        {% elif pdf.file_exists == False %}
          <span class="file-status status-missing">⚠ missing</span><br>
          <small class="muted">{{ pdf.path }}</small>
        {% else %}
          <small class="muted">{{ pdf.path }}</small>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
    </tbody></table>
    {% endif %}
    <button class="action-btn" onclick="openModal('modal-reference')">+ Add reference (PDF)</button>
  </div>

  <!-- Expert knowledge panel -->
  <div class="panel">
    <h3>Expert knowledge</h3>
    <p class="panel-lead">Curated expert documents &mdash; PDFs, lab notes, expert review docs &mdash; that aren&rsquo;t formal publications but capture domain knowledge driving the model. Linked to the claims they support.</p>
    {% if expert_docs %}
    <table><thead><tr><th>Name</th><th>File</th><th>Description</th><th>Contributor</th><th>Claims</th></tr></thead><tbody>
    {% for doc in expert_docs %}
    <tr>
      <td><strong>{{ doc.name }}</strong></td>
      <td>
        {% if doc.file_exists %}
          {% if doc.sha256_valid == False %}<span class="file-status status-mismatch" title="sha256 in workspace.yaml doesn't match disk">⚠ sha mismatch</span>{% else %}<span class="file-status status-ok">✓ {{ doc.size_human }}</span>{% endif %}
          <a href="/{{ doc.path }}" target="_blank" class="file-link">Open ↗</a><br>
          <small class="muted">{{ doc.path }}</small>
        {% elif doc.file_exists == False %}
          <span class="file-status status-missing" title="path in workspace.yaml does not exist on disk">⚠ missing</span><br>
          <small class="muted">{{ doc.path }}</small>
        {% else %}
          <small class="muted">{{ doc.path or '(no path)' }}</small>
        {% endif %}
      </td>
      <td>{{ doc.description or '' }}</td>
      <td>{{ doc.contributor or '' }}</td>
      <td>{{ (doc.claims_supported or [])|join(', ') }}</td>
    </tr>
    {% endfor %}
    </tbody></table>
    {% else %}
    <p style="color:#888;font-style:italic">No expert documents registered yet.</p>
    {% endif %}
    <button class="action-btn" onclick="openModal('modal-expert-doc')">+ Add expert document</button>
  </div>

</section>

<!-- ===== PAGE: SIMULATION SETUP ===== -->
<section id="page-simulation-setup" class="page" data-page="simulation-setup">
  <h2 class="page-title">Composites</h2>
  <p class="page-lead">Browse and explore the composites available in this workspace. Each composite packages a runnable simulation state with parameters you can configure. Click <strong>Explore</strong> to open its wiring diagram and start a Study.</p>

  <!-- Available Composites (workspace-local discovery) -->
  <div class="panel">
    <h3>Available Composites <span id="composite-count" class="count-badge"></span></h3>
    <p class="panel-lead">Discoverable composite documents from <code>pbg_&lt;slug&gt;/composites/*.composite.{yaml,json}</code>. Each one packages a runnable simulation state with parameters you can configure. Click <strong>Explore</strong> to open it in Composite Explorer.</p>
    <div class="card-browse-toolbar" id="composite-toolbar">
      <input type="search" class="card-browse-search" id="composite-search" placeholder="Filter composites…">
      <div class="card-browse-chips" id="composite-tag-chips"></div>
      <span class="card-browse-view-toggle">
        <button class="view-btn active" data-view="grid" onclick="_setCompositeView('grid')" title="Grid view">&#9638;</button>
        <button class="view-btn" data-view="list" onclick="_setCompositeView('list')" title="List view">&#8801;</button>
      </span>
      <select id="composites-sort" class="composites-sort-select" onchange="_setCompositesSort(this.value)" title="Sort composites">
        <option value="name">Sort: Name</option>
        <option value="module">Sort: Module</option>
        <option value="kind">Sort: Kind</option>
      </select>
    </div>
    <div id="composite-cards" class="module-grid">
      <p class="empty-state">Loading composites&hellip;</p>
    </div>
  </div>

</section>

<!-- ===== PAGE: VISUALIZATIONS ===== -->
<section id="page-visualizations" class="page" data-page="visualizations">
  <h2 class="page-title">Visualizations</h2>
  <p class="page-lead">Charts rendered from observable trajectories. Either configure a registered class with specific settings, or describe what to plot in natural language and let <code>/pbg-viz</code> generate the function.</p>


  <!-- Workspace visualizations (workspace.yaml-driven, primary panel) -->
  <div class="panel">
    <h3>Workspace visualizations</h3>
    <p class="panel-lead">Configured visualizations registered in <code>workspace.yaml</code>. <strong>Class-backed</strong> entries are ready to use immediately in investigations. <strong>Description-only</strong> entries follow the Create/Add/Commit lifecycle to generate code via <code>/pbg-viz</code>.</p>
    <div style="margin-bottom:8px">
      <button class="action-btn" onclick="_openWorkspaceVizModal()">+ Add visualization</button>
      <button class="action-btn" onclick="_vizCommitAll()">Commit all staged</button>
    </div>
    {% if visualizations %}
    <table><thead><tr><th>Name</th><th>Class / Description</th><th>Config</th><th>Status</th><th>Actions</th></tr></thead><tbody>
    {% for viz in visualizations %}
    <tr id="viz-row-{{ viz.name }}">
      <td><code>{{ viz.name }}</code>{% if viz.type %}<br><small style="color:#888">{{ viz.type }}{% if viz.observables %}: {{ viz.observables | join(', ') }}{% endif %}</small>{% endif %}</td>
      <td class="viz-description">
        {% if viz.class %}<strong>{{ viz.class }}</strong>{% if viz.description %}<br>{% endif %}{% endif %}
        {% if viz.description %}{{ viz.description }}{% elif not viz.class and not viz.type %}<em style="color:#888">No description</em>{% endif %}
      </td>
      <td><small style="color:#666;font-family:monospace">{% if viz.config %}{{ viz.config | tojson }}{% else %}—{% endif %}</small></td>
      <td><span class="status-pill" id="viz-status-{{ viz.name }}">…</span></td>
      <td class="viz-actions">
        <button class="btn-mini" onclick="_vizPreview('{{ viz.name }}')">Preview</button>
        {% if viz.description and not viz.class %}<button class="btn-mini" onclick="_vizCreate('{{ viz.name }}')">Create</button>{% endif %}
        <button class="btn-mini" onclick="_vizAddToProject('{{ viz.name }}')">Add to project</button>
        <button class="btn-mini" onclick="_vizCommit(['{{ viz.name }}'])">Commit</button>
        <button class="btn-mini" onclick="_vizRemove('{{ viz.name }}')" style="color:#c00">Remove</button>
      </td>
    </tr>
    {% endfor %}
    </tbody></table>
    {% else %}
    <p style="color:#888;font-style:italic">No visualizations registered yet.</p>
    {% endif %}
  </div>

  <!-- Available Visualization classes (registry-driven, secondary catalog) -->
  <div class="panel">
    <h3>Available Visualization classes <span id="viz-count" class="count-badge"></span></h3>
    <p class="panel-lead">Visualization classes discovered from <code>core.link_registry</code> (subclasses of <code>pbg_superpowers.visualization.Visualization</code> from any installed pbg-* package). Click <strong>Preview</strong> to see a demo render; <strong>Use</strong> to register it as a Workspace visualization.</p>
    <input type="search" id="viz-catalog-search" placeholder="Search Visualization classes by name or doc…"
           style="width:100%;padding:6px;margin-bottom:8px;font-size:0.9em"
           oninput="_filterVizCatalog(this.value)">
    <div id="viz-picker-container">
      <p class="empty-state">Loading from Registry&hellip;</p>
    </div>
  </div>

  <!-- Generate new visualization class -->
  <div class="panel">
    <h3>Generate new visualization class</h3>
    <p class="panel-lead">Nothing in the catalog above matches? Describe what you want. The
      <code>/pbg-viz</code> skill writes a decorated function to
      <code>&lt;workspace_pkg&gt;/visualizations/&lt;snake&gt;.py</code>. After accepting, the new
